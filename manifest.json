{
  "manifest_version": 3,
  "name": "1440p Video Upscaler",
  "version": "1.0.0",
  "description": "Upscales 720p and 1080p videos to 2560×1440 in real-time. Controlled entirely from the extension popup.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "1440p Upscaler"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_idle",
    "all_frames": true
  }],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
